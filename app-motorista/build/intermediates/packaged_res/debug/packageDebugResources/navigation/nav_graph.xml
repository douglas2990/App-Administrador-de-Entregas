<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.douglas2990.app_motorista.presentation.ui.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_minhaAgendaFragment"
            app:destination="@id/minhaAgendaFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/minhaAgendaFragment"
        android:name="com.douglas2990.app_motorista.presentation.ui.MinhaAgendaFragment"
        android:label="Minha Agenda">
        <action
            android:id="@+id/action_minhaAgenda_to_rotasMotoristaFragment"
            app:destination="@id/rotasMotoristaFragment" />
    </fragment>

    <fragment
        android:id="@+id/rotasMotoristaFragment"
        android:name="com.douglas2990.app_motorista.presentation.ui.RotasMotoristaFragment"
        android:label="Minhas Rotas"
        tools:layout="@layout/fragment_rotas_motorista">

        <argument
            android:name="dataSelecionada"
            app:argType="long" />

        <action
            android:id="@+id/action_rotasMotoristaFragment_to_detalhesEntregaFragment"
            app:destination="@id/detalhesEntregaFragment" />
    </fragment>

    <fragment
        android:id="@+id/detalhesEntregaFragment"
        android:name="com.douglas2990.app_motorista.presentation.ui.DetalhesEntregaFragment"
        android:label="Entregas do Dia"
        tools:layout="@layout/fragment_detalhes_entrega">
        <argument
            android:name="dataSelecionada"
            app:argType="long" />
        <argument
            android:name="rota"
            app:argType="com.example.core.model.Rota"
            app:nullable="true" />
    </fragment>

</navigation>