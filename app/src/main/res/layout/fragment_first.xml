<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FirstFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <Button
            android:id="@+id/button_first"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/next"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <Button
            android:id="@+id/button_cadastrarEmpresaFragment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cadastrar Empresa Fragment"
            app:layout_constraintTop_toBottomOf="@id/button_first"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/button_CadastrarMotoristaFragment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cadastrar Motorista Fragment"
            app:layout_constraintTop_toBottomOf="@id/button_cadastrarEmpresaFragment"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/button_MostrarMotoristaCadastradoFragment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mostrar Motoristas Cadastrados "
            app:layout_constraintTop_toBottomOf="@id/button_CadastrarMotoristaFragment"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/button_CadastrarLoginMotorista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cadastrar LOGIN Motorista "
            app:layout_constraintTop_toBottomOf="@id/button_MostrarMotoristaCadastradoFragment"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />





    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>